generator client {
  provider = "prisma-client-py"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id          String    @id @default(uuid())
  name        String
  plan        String    @default("free")
  users       User[]
  candidates  Candidate[]
  jobPosts    JobDescription[]
  analytics   AnalyticsEvent[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  hashedPassword String
  name           String?
  role           UserRole        @default(USER)
  organization   Organization    @relation(fields: [organizationId], references: [id])
  organizationId String
  resumes        Resume[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

enum UserRole {
  USER
  ADMIN
}

model Candidate {
  id             String          @id @default(uuid())
  organization   Organization    @relation(fields: [organizationId], references: [id])
  organizationId String
  name           String
  email          String?
  phone          String?
  currentTitle   String?
  resumes        Resume[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Resume {
  id             String            @id @default(uuid())
  candidate      Candidate         @relation(fields: [candidateId], references: [id])
  candidateId    String
  organization   Organization      @relation(fields: [organizationId], references: [id])
  organizationId String
  uploadedBy     User              @relation(fields: [uploadedById], references: [id])
  uploadedById   String
  filePath       String
  fileName       String
  status         ResumeStatus      @default(PENDING)
  parsedAt       DateTime?
  analyses       ResumeAnalysis[]
  sections       ResumeSection[]
  skills         ResumeSkill[]
  chatDocs       ChatDocument[]
  interviewItems InterviewQuestion[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

enum ResumeStatus {
  PENDING
  PARSED
  FAILED
}

model JobDescription {
  id             String            @id @default(uuid())
  organization   Organization      @relation(fields: [organizationId], references: [id])
  organizationId String
  title          String
  description    String
  rawText        String
  createdBy      User              @relation(fields: [createdById], references: [id])
  createdById    String
  analyses       ResumeAnalysis[]
  jobSkills      JobSkill[]
  chatDocs       ChatDocument[]
  interviewItems InterviewQuestion[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model ResumeAnalysis {
  id                 String          @id @default(uuid())
  resume             Resume          @relation(fields: [resumeId], references: [id])
  resumeId           String
  jobDescription     JobDescription  @relation(fields: [jobDescriptionId], references: [id])
  jobDescriptionId   String
  scoreOverall       Float
  scoreSkills        Float
  scoreExperience    Float
  scoreEducation     Float
  scoreATS           Float
  recommendation     String
  missingSkills      String[]
  analysisJson       Json
  createdAt          DateTime        @default(now())
}

model ResumeSection {
  id             String   @id @default(uuid())
  resume         Resume   @relation(fields: [resumeId], references: [id])
  resumeId       String
  sectionType    SectionType
  content        String
  extractedJson  Json
  createdAt      DateTime @default(now())
}

enum SectionType {
  SUMMARY
  EDUCATION
  EXPERIENCE
  SKILLS
  PROJECTS
  CERTIFICATIONS
  OTHER
}

model Skill {
  id            String         @id @default(uuid())
  name          String         @unique
  category      String?
  normalized    String
  resumeSkills  ResumeSkill[]
  jobSkills     JobSkill[]
}

model ResumeSkill {
  id        String   @id @default(uuid())
  resume    Resume   @relation(fields: [resumeId], references: [id])
  resumeId  String
  skill     Skill    @relation(fields: [skillId], references: [id])
  skillId   String
  source    String
  confidence Float
  createdAt DateTime @default(now())
}

model JobSkill {
  id         String         @id @default(uuid())
  job        JobDescription @relation(fields: [jobDescriptionId], references: [id])
  jobDescriptionId String
  skill      Skill          @relation(fields: [skillId], references: [id])
  skillId    String
  importance Int            @default(1)
}

model ChatDocument {
  id             String       @id @default(uuid())
  resume         Resume?      @relation(fields: [resumeId], references: [id])
  resumeId       String?
  jobDescription JobDescription? @relation(fields: [jobDescriptionId], references: [id])
  jobDescriptionId String?
  chunkText      String
  embedding      Json
  metadata       Json
  createdAt      DateTime     @default(now())
}

model InterviewQuestion {
  id             String          @id @default(uuid())
  resume         Resume?         @relation(fields: [resumeId], references: [id])
  resumeId       String?
  jobDescription JobDescription? @relation(fields: [jobDescriptionId], references: [id])
  jobDescriptionId String?
  questionText   String
  category       String?
  createdAt      DateTime        @default(now())
}

model AnalyticsEvent {
  id             String    @id @default(uuid())
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  user           User?     @relation(fields: [userId], references: [id])
  userId         String?
  eventType      String
  payload        Json
  timestamp      DateTime  @default(now())
}
